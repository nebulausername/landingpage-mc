# ──────────────────────────────────────────────────────────────────
# landing-mc · environment variables
# ──────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local dev. For Vercel, add each
# variable in Project → Settings → Environment Variables instead.

# ──────────────────────────────────────────────────────────────────
# Admin panel
# Reach the admin at /admin and log in with this password.
# Unset → admin is fully disabled and /admin returns a setup screen.
# Use 12+ random characters in production.
ADMIN_PASSWORD=

# ──────────────────────────────────────────────────────────────────
# Newsletter / lead capture
# Where /api/contact submissions are forwarded as Discord embeds.
# Create one in Discord: Server Settings → Integrations → Webhooks
# → New Webhook → Copy URL.
CONTACT_WEBHOOK_URL=

# Optional — site URL override for SEO/OG (defaults to config.siteUrl)
# NEXT_PUBLIC_SITE_URL=https://oakhaven.gg
